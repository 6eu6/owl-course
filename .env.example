# =============================================
# OWL COURSE - Environment Variables
# =============================================

# ===== DATABASE (Required) =====
# Your Prisma Postgres connection URL
# Example: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY
# Or: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ===== PUBLISHING BOT (Posts courses to channels) =====
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ===== ADMIN BOT (Separate bot for admin commands via Telegram) =====
ADMIN_BOT_TOKEN=
# Comma-separated chat IDs allowed to use admin bot (e.g., "123456789,987654321")
ADMIN_CHAT_IDS=

# ===== ADMIN PASSWORD =====
# Default is "owl2024" if not set. Change this!
ADMIN_PASSWORD=

# ===== SITE URL (Optional) =====
# Your deployed site URL (for Telegram messages, sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
