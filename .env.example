# =============================================
# OWL COURSE - Environment Variables
# =============================================

# ===== DATABASE (Required) =====
# SQLite database path (for local development)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ===== MONGODB (Optional - for production) =====
# If you prefer MongoDB Atlas for production, set this:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/owlcourse

# ===== SITE CONFIG =====
# Public URL of your site (used in Telegram messages)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ===== ADMIN (Optional) =====
# Simple admin password protection for /admin route
# ADMIN_PASSWORD=your-secure-password

# ===== TELEGRAM (Configure in admin panel) =====
# These can also be set in the admin panel UI
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHANNEL_ID=@your-channel

# ===== VERCEL DEPLOYMENT =====
# When deploying to Vercel, set these in Vercel Environment Variables:
# DATABASE_URL=file:./db/custom.db  (or use Vercel Postgres)
# NEXT_PUBLIC_SITE_URL=https://your-vercel-app.vercel.app
