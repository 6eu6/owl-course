# =============================================
# Learn Plus Courses - Environment Variables
# =============================================
# Copy to .env (which is git-ignored) and fill in real values.
# Never commit real secrets. If a value was ever committed/exposed, rotate it.

# ===== DATABASE (Required) =====
# Your Prisma Postgres connection URL
# Example: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY
# Or: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ===== PUBLISHING BOT (Posts courses to channels) =====
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ===== ADMIN BOT (Separate bot for admin commands via Telegram) =====
ADMIN_BOT_TOKEN=
# Comma-separated chat IDs allowed to use admin bot (e.g., "123456789,987654321")
ADMIN_CHAT_IDS=

# ===== ADMIN PASSWORD (Admin dashboard only) =====
# Falls back to a built-in default if unset — always set a strong value.
ADMIN_PASSWORD=

# ===== CRON SECRET (/api/cron/scrape only) =====
# Keep this separate from ADMIN_PASSWORD so the admin password never ends up in cron URLs/logs.
CRON_SECRET=

# ===== SITE URL =====
# Your deployed site URL (for Telegram messages, sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://www.learn-plus.uk
