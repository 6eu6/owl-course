# =============================================
# OWL COURSE - Environment Variables
# =============================================

# ===== DATABASE (Required) =====
# Local development (SQLite):
DATABASE_URL=file:/home/z/my-project/db/owlcourse.db

# Vercel/Production (Prisma Postgres - change provider in schema.prisma to "postgresql"):
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# Or Prisma Accelerate:
# DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY

# ===== SITE CONFIG =====
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ===== ADMIN =====
# Default admin password is "owl2024" - change in admin panel
