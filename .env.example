# =============================================
# Learn Plus Courses - Environment Variables
# =============================================
# Copy to .env (which is git-ignored) and fill in real values.
# Never commit real secrets. If a value was ever committed/exposed, rotate it.

# ===== DATABASE (Required) =====
# Your Prisma Postgres connection URL
# Example: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY
# Or: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ===== MIGRATION DATABASE URL (only for /api/cron/i18n-bootstrap) =====
# A connection string for a role that OWNS / can CREATE in the public schema.
# Used solely by the temporary i18n-bootstrap endpoint to create the
# CourseTranslation / TelegramPost tables. Runtime never uses this.
# Use a DIRECT Postgres connection (not the Accelerate proxy), e.g.:
#   postgres://OWNER_USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# Remove it again after the migration has been applied and confirmed.
MIGRATION_DATABASE_URL=

# ===== PUBLISHING BOT (Posts courses to channels) =====
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ===== ADMIN BOT (Separate bot for admin commands via Telegram) =====
ADMIN_BOT_TOKEN=
# Comma-separated chat IDs allowed to use admin bot (e.g., "123456789,987654321")
ADMIN_CHAT_IDS=

# ===== ADMIN PASSWORD (Admin dashboard only) =====
# Falls back to a built-in default if unset — always set a strong value.
ADMIN_PASSWORD=

# ===== CRON SECRET (/api/cron/scrape only) =====
# Keep this separate from ADMIN_PASSWORD so the admin password never ends up in cron URLs/logs.
CRON_SECRET=

# ===== SITE URL =====
# Your deployed site URL (for Telegram messages, sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://www.learn-plus.uk

# ===== ARABIC TRANSLATION (only needed for /api/cron/translate?locale=ar) =====
# Works with any OpenAI-compatible chat/completions endpoint. English (locale=en)
# needs none of these. Pick ONE free provider and fill the three values:
#
#   Groq (free, fast):
#     TRANSLATION_API_URL=https://api.groq.com/openai/v1/chat/completions
#     TRANSLATION_MODEL=llama-3.3-70b-versatile
#     TRANSLATION_API_KEY=gsk_...           (from console.groq.com)
#
#   Google Gemini (free tier, OpenAI-compatible endpoint):
#     TRANSLATION_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#     TRANSLATION_MODEL=gemini-2.0-flash
#     TRANSLATION_API_KEY=...               (from aistudio.google.com/apikey)
#
#   OpenAI (paid, default if TRANSLATION_API_URL is unset):
#     TRANSLATION_MODEL=gpt-4o-mini
#     TRANSLATION_API_KEY=sk-...
#
TRANSLATION_API_URL=
TRANSLATION_MODEL=
TRANSLATION_API_KEY=
