# =============================================
# OWL COURSE - Environment Variables
# =============================================

# ===== DATABASE (Required) =====
# Your Prisma Postgres connection URL
# Example: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY
# Or: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ===== SITE URL (Optional) =====
# Your deployed site URL (for Telegram messages, sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
