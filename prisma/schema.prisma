// OWL COURSE - Udemy Free Course Scraper
// Prisma Schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./db/courses.db"
}

model Course {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String    @default("")
  instructor     String    @default("")
  category       String    @default("Other")
  imageUrl       String    @default("")
  udemyUrl       String    @unique
  source         String    @default("manual")
  rating         Float?
  studentsCount  Int?
  originalPrice  String?
  language       String?
  duration       String?
  requirements   String    @default("")
  whoFor         String    @default("")
  whatLearn      String    @default("")
  lastUpdated    String?
  couponCode     String    @default("")
  couponUrl      String    @default("")
  couponExpiresAt DateTime?
  isFreeForever  Boolean   @default(false)
  sourceDetail   String?
  scrapeRunId    String?
  isPublished    Boolean   @default(true)
  telegramPosted Boolean   @default(false)
  telegramPostedAt DateTime?
  scrapedAt      DateTime  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@index([source])
  @@index([category])
  @@index([isPublished])
}

model ScraperLog {
  id        String   @id @default(cuid())
  source    String
  status    String   @default("success")
  newCount  Int      @default(0)
  dupCount  Int      @default(0)
  errCount  Int      @default(0)
  message   String   @default("")
  duration  Int      @default(0)
  timestamp DateTime @default(now())
}

model Setting {
  id        String   @id
  value     String
  updatedAt DateTime @updatedAt
}
