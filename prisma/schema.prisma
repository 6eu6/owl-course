// OWL COURSE - Udemy Free Course Scraper
// Prisma Schema (Prisma Postgres)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String    @default("")
  instructor     String    @default("")
  category       String    @default("Other")
  imageUrl       String    @default("")
  udemyUrl       String    @unique
  source         String    @default("manual") // udemyfreebies | studybullet | manual
  rating         Float?
  studentsCount  Int?
  originalPrice  String?
  language       String?
  duration       String?
  requirements   String    @default("")
  whoFor         String    @default("")
  whatLearn      String    @default("")
  lastUpdated    String?
  couponCode     String?   @default("")
  couponUrl      String?   @default("")
  isPublished    Boolean   @default(true)
  telegramPosted Boolean   @default(false)
  telegramPostedAt DateTime?
  scrapedAt      DateTime  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@index([source])
  @@index([category])
  @@index([isPublished])
  @@index([telegramPosted])
  @@index([scrapedAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String   @default("📚")
  courseCount Int      @default(0)
  createdAt   DateTime @default(now())
}

model TelegramChannel {
  id        String   @id @default(cuid())
  name      String
  chatId    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id
  value     String
  group     String   @default("general") // general | scraper | telegram | ui
  updatedAt DateTime @updatedAt
}

model ScraperLog {
  id        String   @id @default(cuid())
  source    String   // udemyfreebies | studybullet
  status    String   @default("success") // success | error | partial
  newCount  Int      @default(0)
  dupCount  Int      @default(0)
  errCount  Int      @default(0)
  message   String   @default("")
  duration  Int      @default(0) // ms
  timestamp DateTime @default(now())

  @@index([source])
  @@index([timestamp])
}

model TelegramMessage {
  id          String   @id @default(cuid())
  courseId    String?
  courseTitle String
  channels    String   // JSON array of channel names
  status      String   @default("sent") // sent | failed | pending
  sentAt      DateTime @default(now())

  @@index([status])
  @@index([sentAt])
}
